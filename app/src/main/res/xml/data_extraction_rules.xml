<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the database from Cloud Backup to prevent stale data from being restored. -->
        <exclude domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <!-- Allow databases to be transferred directly between devices (e.g., during phone setup) -->
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>